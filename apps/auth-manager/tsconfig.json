{
  "extends": "@map-colonies/tsconfig/tsconfig-app",
  "compilerOptions": {
    "baseUrl": ".",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@src/*": ["./src/*"],
      "@common/*": ["./src/common/*"],
      "@tests/*": ["./tests/*"],
      "@client/*": ["./src/client/*"],
      "@domain/*": ["./src/domain/*"],
      "@key/*": ["./src/key/*"],
      "@connection/*": ["./src/connection/*"],
      "@openapi": ["src/openapi.js"]
    }
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}
