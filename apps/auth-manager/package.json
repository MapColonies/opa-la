{
  "name": "auth-manager",
  "version": "1.12.0",
  "description": "API server for managing all the authentication data",
  "dockerfile": "docker/backend.Dockerfile",
  "author": "MapColonies",
  "type": "commonjs",
  "homepage": "https://github.com/MapColonies/opa-la#readme",
  "license": "MIT",
  "main": "dist/index.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MapColonies/opa-la.git"
  },
  "scripts": {
    "test:unit": "vitest run --coverage.enabled=false --project unit",
    "test:integration": "vitest run --coverage.enabled=false --project integration",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prebuild": "npm run clean",
    "build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json && npm run assets:copy",
    "build:docker": "docker buildx build --build-arg APP_NAME=$npm_package_name -f ../../docker/backend.Dockerfile -t ${DOCKER_REGISTRY:-}${npm_package_name}:${DOCKER_TAG:-latest} ${DOCKER_FLAGS:-} ../..",
    "build:docker-no-cache": "cross-env DOCKER_FLAGS=--no-cache pnpm run build:docker",
    "start": "npm run build && cd dist && node --import ./instrumentation.mjs ./index.js",
    "start:dev": "npm run build && cd dist && cross-env CONFIG_OFFLINE_MODE=true  node --enable-source-maps --import ./instrumentation.mjs ./index.js",
    "assets:copy": "copyfiles -f ./config/* ./dist/config && copyfiles -f ./openapi3.yaml ./dist/ && copyfiles ./dataSource.mjs dist && copyfiles ./package.json dist",
    "clean": "rimraf dist",
    "knip": "knip --directory ../.. --workspace apps/auth-manager"
  },
  "bugs": {
    "url": "https://github.com/MapColonies/opa-la/issues"
  },
  "dependencies": {
    "@godaddy/terminus": "catalog:",
    "@map-colonies/auth-core": "workspace:^",
    "@map-colonies/config": "catalog:",
    "@map-colonies/error-express-handler": "catalog:",
    "@map-colonies/express-access-log-middleware": "catalog:",
    "@map-colonies/js-logger": "catalog:",
    "@map-colonies/openapi-express-viewer": "catalog:",
    "@map-colonies/read-pkg": "catalog:",
    "@map-colonies/schemas": "catalog:",
    "@map-colonies/prometheus": "catalog:",
    "@map-colonies/tracing": "catalog:",
    "@map-colonies/tracing-utils": "catalog:",
    "@opentelemetry/api": "catalog:",
    "auth-openapi": "workspace:^",
    "body-parser": "catalog:",
    "compression": "catalog:",
    "cors": "^2.8.5",
    "date-fns": "catalog:",
    "express": "catalog:",
    "express-openapi-validator": "catalog:",
    "http-status-codes": "catalog:",
    "jose": "catalog:",
    "pg": "catalog:",
    "prom-client": "catalog:",
    "reflect-metadata": "catalog:",
    "tsyringe": "catalog:",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@map-colonies/openapi-helpers": "catalog:",
    "@map-colonies/tsconfig": "catalog:",
    "test-utils": "workspace:^",
    "@types/body-parser": "catalog:",
    "@types/compression": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/supertest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "jest-extended": "catalog:",
    "jest-openapi": "catalog:",
    "supertest": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@map-colonies/vitest-utils": "catalog:",
    "@map-colonies/eslint-config": "catalog:",
    "@faker-js/faker": "catalog:"
  }
}
