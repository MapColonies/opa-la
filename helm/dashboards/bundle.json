        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          },
          "editorMode": "code",
          "expr": "(((max by (instance) (((time() - last_bundle_request/1e9) > ($grace_window_minutes * 60)) and on(instance) last_success_bundle_activation{namespace=~\"$ns\"})) * 0 + 2) or ((max by (instance) (last_success_bundle_activation{namespace=~\"$ns\"} unless on(active_revision) label_replace(vector(1), \"active_revision\", \"$latest_revision\", \"\", \"\"))) * 0 + (1 + $grace_expired)))",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "D"
        }
