          "expr": "min(time() - (last_bundle_request{namespace=~\"$ns\"} / 1e9))",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Pod poll liveness ($env)",
      "type": "stat"
    }
