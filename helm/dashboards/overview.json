    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "99th-percentile latency of decision requests for OPA pods serving the selected environment.",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
