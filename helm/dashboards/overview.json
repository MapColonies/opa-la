      "links": [
        {
          "targetBlank": true,
          "title": "Open Performance",
          "url": "/d/opala-performance/performance"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
